# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Your Telegram chat ID (only this user can use the bot)
ADMIN_CHAT_ID=123456789

# Google AI Studio / Gemini API key
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Hugging Face Inference Providers (for /hugging_face video generation)
HF_TOKEN=hf_your_token_with_inference_providers
HF_VIDEO_MODEL=Lightricks/LTX-Video-0.9.8-13B-distilled
HF_I2V_MODEL=Wan-AI/Wan2.2-I2V-A14B
HF_PROVIDER=auto
HF_TARGET_DURATION_SECONDS=12

# YouTube OAuth (download client_secret.json from Google Cloud Console)
YOUTUBE_CLIENT_SECRETS_FILE=secrets/client_secret.json
YOUTUBE_TOKEN_FILE=secrets/youtube_token.json
YOUTUBE_PRIVACY_STATUS=private
YOUTUBE_CATEGORY_ID=22

# Local storage
VIDEO_STORAGE_DIR=storage/videos
SESSION_TTL_HOURS=24
